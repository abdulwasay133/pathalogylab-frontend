{
  "name": "argon-dashboard-react",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "homepage": "/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/creativetimofficial/argon-dashboard-react.git"
  },
  "keywords": [
    "react",
    "reactjs",
    "argon",
    "argon-react",
    "dashboard",
    "dashboard-react",
    "argon-dashboard",
    "argon-dashboard-react"
  ],
  "author": "Creative Tim",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/creativetimofficial/argon-dashboard-react/issues"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "electron:dev": "concurrently \"cross-env BROWSER=none npm start\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:preview": "npm run build && electron ."
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fortawesome/fontawesome-free": "^6.5.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/lab": "^7.0.1-beta.23",
    "@mui/material": "^7.3.9",
    "@mui/x-data-grid": "^8.27.3",
    "ajv": "^8.16.0",
    "bootstrap": "^4.6.2",
    "chart.js": "^2.9.4",
    "classnames": "^2.3.2",
    "dompurify": "^3.3.2",
    "moment": "2.29.4",
    "nouislider": "15.4.0",
    "react": "18.2.0",
    "react-barcode": "^1.6.1",
    "react-chartjs-2": "^2.11.2",
    "react-copy-to-clipboard": "5.1.0",
    "react-datepicker": "^9.1.0",
    "react-datetime": "3.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^6.30.3",
    "react-scripts": "5.0.1",
    "react-to-print": "^3.3.0",
    "react-toastify": "^11.0.5",
    "reactstrap": "^8.10.0",
    "sass": "1.69.5"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "gulp": "4.0.2",
    "gulp-append-prepend": "1.0.9",
    "wait-on": "^9.0.4"
  },
  "optionalDependencies": {
    "eslint-plugin-flowtype": "8.0.3",
    "typescript": "5.3.3"
  },
  "overrides": {
    "svgo": "3.0.2",
    "fsevents": "2.3.2",
    "chokidar": "3.5.3"
  },
  "build": {
    "appId": "com.yourname.yourapp",
    "productName": "LIMS Dashboard",
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "asar": false,
    "files": [
      "build/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "dist-electron",
      "buildResources": "assets"
    },
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "forceCodeSigning": false
    }
  }
}